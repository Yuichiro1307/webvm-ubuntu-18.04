FROM --platform=linux/386 docker.io/i386/ubuntu:18.04

ARG DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    xfce4 \
    xfce4-terminal \
    dbus-x11 \
    x11-xserver-utils \
    xauth \
    sudo \
    vim \
    curl \
    git \
    python3 \
    python3-pip \
    gcc \
    make \
    net-tools \
    procps

WORKDIR /root

ENV HOME="/root" \
    TERM="xterm" \
    USER="root" \
    SHELL="/bin/bash" \
    DISPLAY=":0"

CMD ["/usr/bin/startxfce4"]
