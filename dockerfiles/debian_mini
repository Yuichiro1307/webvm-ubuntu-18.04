FROM i386/ubuntu:18.04

ARG DEBIAN_FRONTEND=noninteractive

RUN echo "deb http://old-releases.ubuntu.com/ubuntu xenial main universe multiverse" > /etc/apt/sources.list

RUN apt-get update || true && apt-get install -y \
    bash \
    coreutils \
    util-linux \
    vim \
    curl \
    netcat \
    python3 \
    gcc \
    make

RUN useradd -m user && echo "user:password" | chpasswd

ENV HOME="/home/user" TERM="xterm" USER="user" SHELL="/bin/bash"

WORKDIR /home/user

CMD ["/bin/bash"]
